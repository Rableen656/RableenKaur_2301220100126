#include <iostream>
#include <vector>
using namespace std;


int linearSearch(vector<int>& nums, int target) {
    int n = nums.size();

    for(int i = 0; i < n; i++) {
        if(nums[i] == target) {
            return i; 
        }
    }
    return -1; 
}

int main() {
    vector<int> nums = {2, 7, 11, 15, 6, 4};
    int target = 15;

    int index = linearSearch(nums, target);

    if(index!= -1)
        cout << target << " Found " << index << " pe";
    else
        cout << target << " Not found";

    return 0;
}
