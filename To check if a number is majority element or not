#include <iostream>
#include <vector>
using namespace std;

bool isMajority(vector<int>& nums, int no) {
    int n = nums.size();
    int count = 0;

    // Bas 'no' ko count kar lo
    for(int i = 0; i < n; i++) {
        if(nums[i] == no) {
            count++;
        }
    }

    // Majority condition: count > n/2
    return count > n/2;
}

int main() {
    vector<int> nums = {2, 2, 9, 3, 9, 2, 2};
    int no = 2;

    if(isMajority(nums, no))
        cout << no << " is Majority Element";
    else
        cout << no << " is NOT Majority Element";

    return 0;
}
// Output: 2 is Majority Element
