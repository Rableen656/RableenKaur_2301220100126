#include <iostream>
#include <string>
using namespace std;

bool isPalindrome(string s) {
    int start = 0;
    int end = s.length() - 1; // last index

    while (start < end) {
        if (s[start]!= s[end]) {
            return false; // milte hi false, aage check karne ki zarurat nahi
        }
        start++; // aage badho
        end--; // peeche aao
    }
    return true; // sab match ho gaya
}

int main() {
    string str;
    cout << "Enter a string: ";
    cin >> str;

    if (isPalindrome(str)) {
        cout << str << " is a Palindrome ✅" << endl;
    } else {
        cout << str << " is Not a Palindrome ❌" << endl;
    }

    return 0;
}
